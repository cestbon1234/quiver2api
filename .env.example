# Quiver2API local configuration.
# Copy this file to .env for local development. Keep .env private.

# Server port. Defaults to 3000 when omitted.
PORT=3000

# Optional local API key for /v1 endpoints.
# When set, clients must send: Authorization: Bearer <key>
QUIVER2API_KEY=

# Optional SQLite database path for accounts, sessions, and saved config.
# Relative paths are resolved from the project root.
QUIVER2API_DB=accounts.db

# Optional official QuiverAI API key for /api/official/* routes.
QUIVERAI_API_KEY=

# Optional YYDS Mail API key for automatic registration.
YYDS_API_KEY=

# Optional HTTP/HTTPS proxy for Quiver and mailbox API requests.
# Example: http://127.0.0.1:7890
QUIVER_PROXY=
